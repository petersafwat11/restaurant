# =========================================================================
# Production .env for the restaurant stack — copy to /opt/restaurant/.env on
# the VPS, fill in real values, chmod 600. NEVER commit a filled-in copy.
# Generate secrets locally with:
#   openssl rand -base64 48
# =========================================================================

# ---- Domain + Caddy ----
DOMAIN=example.com
CADDY_EMAIL=you@example.com
# Leading dot so cookies issued by api.example.com are also sent to the
# bare example.com (web SSR middleware needs to see auth cookies).
COOKIE_DOMAIN=.example.com

# ---- App URLs (must match DOMAIN and the three subdomains) ----
APP_URL_WEB=https://example.com
APP_URL_ADMIN=https://admin.example.com
APP_URL_API=https://api.example.com
APP_DEEP_LINK_SCHEME=restaurant

# ---- Image tags (set by CI to a specific :sha-* on deploy) ----
API_IMAGE=ghcr.io/petersafwat11/restaurant-api
WEB_IMAGE=ghcr.io/petersafwat11/restaurant-web
ADMIN_IMAGE=ghcr.io/petersafwat11/restaurant-admin
IMAGE_TAG=latest

# ---- Postgres (compose-internal) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_strong_password_here
POSTGRES_DB=restaurant

# ---- JWT (generate with openssl rand -base64 48) ----
JWT_ACCESS_SECRET=CHANGEME_at_least_32_chars_long_secret_here
JWT_REFRESH_SECRET=CHANGEME_at_least_32_chars_long_secret_here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Order-tracking HMAC ----
ORDER_TRACKING_SECRET=CHANGEME_generate_with_openssl_rand

# ---- Cookies (lax works because web/admin/api share an eTLD+1) ----
COOKIE_SAMESITE=lax

# ---- Email (Resend) ----
RESEND_API_KEY=
MAIL_FROM=Restaurant <no-reply@example.com>
SMTP_HOST=localhost
SMTP_PORT=1025

# ---- SMS (Twilio) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---- Stripe (deferred at launch — empty values activate the dev stub) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Observability (deferred at launch — leave blank for no-op) ----
SENTRY_DSN=
SENTRY_ENV=production
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com
