# Caddy reverse proxy for the restaurant stack.
# Caddy auto-provisions Let's Encrypt certs for all three hostnames once DNS
# points at the VPS. WebSocket upgrade (Socket.IO) is detected automatically.

{
    email {$CADDY_EMAIL}
    # Use the production ACME endpoint (default). To test changes, swap to:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# Customer web — root domain
{$DOMAIN} {
    encode zstd gzip
    reverse_proxy web:3000
}

# Staff/owner admin
admin.{$DOMAIN} {
    encode zstd gzip
    reverse_proxy admin:3001
}

# API + Socket.IO + uploads static
api.{$DOMAIN} {
    encode zstd gzip
    # Generous client_max for menu image uploads (server enforces 5 MB cap).
    request_body {
        max_size 10MB
    }
    reverse_proxy api:4000
}
