# Version control + editor
.git
.gitignore
.vscode
.idea
*.swp

# Node + build outputs
**/node_modules
**/.next
**/.turbo
**/dist
**/build
**/out
**/.expo
**/*.tsbuildinfo

# Tests + coverage
**/coverage
**/.nyc_output

# Env files (never bake secrets into images)
.env
.env.*
!.env.example

# Logs
**/*.log
npm-debug.log*
pnpm-debug.log*

# Deployment + Claude
.claude
deploy
.playwright-mcp
docker-compose.yml

# Generated artifacts that shouldn't ship in the image
**/packages/db/src/generated
**/.prisma
**/prisma/migrations/dev.db*
dump.rdb

# Mobile
.expo
.expo-shared
*.jks
*.p8
*.p12
*.key
*.mobileprovision
