{
	"extends": "@repo/tsconfig/base.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"noEmit": true,
		"declaration": false,
		"declarationMap": false,
		"sourceMap": false,
		"incremental": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist"]
}
