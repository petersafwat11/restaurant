{
	"name": "@repo/utils",
	"version": "0.0.0",
	"private": true,
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"sideEffects": false,
	"exports": {
		".": "./src/index.ts",
		"./money": "./src/money.ts",
		"./loyalty": "./src/loyalty.ts"
	},
	"typesVersions": {
		"*": {
			"money": ["./src/money.ts"],
			"loyalty": ["./src/loyalty.ts"]
		}
	},
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@prisma/client": "6.1.0"
	},
	"devDependencies": {
		"@repo/tsconfig": "workspace:*",
		"typescript": "5.6.3",
		"vitest": "2.1.8"
	}
}
