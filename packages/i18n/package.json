{
  "name": "@repo/i18n",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./messages": "./src/messages.ts",
    "./messages/*": "./messages/*",
    "./package.json": "./package.json"
  },
  "files": ["src", "messages"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:messages": "node scripts/generate-messages.mjs"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
