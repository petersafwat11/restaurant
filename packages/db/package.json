{
	"name": "@repo/db",
	"version": "0.0.0",
	"private": true,
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"generate": "dotenv -e ../../.env -- prisma generate",
		"migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
		"migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
		"migrate:reset": "dotenv -e ../../.env -- prisma migrate reset --force",
		"seed": "dotenv -e ../../.env -- tsx seed.ts",
		"studio": "dotenv -e ../../.env -- prisma studio",
		"typecheck": "tsc --noEmit",
		"format": "prisma format"
	},
	"prisma": {
		"schema": "prisma/schema.prisma",
		"seed": "dotenv -e ../../.env -- tsx seed.ts"
	},
	"dependencies": {
		"@prisma/client": "6.1.0",
		"bcrypt": "5.1.1"
	},
	"devDependencies": {
		"@repo/tsconfig": "workspace:*",
		"@types/bcrypt": "5.0.2",
		"@types/node": "22.10.5",
		"dotenv-cli": "8.0.0",
		"prisma": "6.1.0",
		"tsx": "4.19.2",
		"typescript": "5.6.3"
	}
}
