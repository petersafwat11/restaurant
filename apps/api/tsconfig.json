{
	"extends": "@repo/tsconfig/nestjs.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"outDir": "./dist",
		"rootDir": ".",
		"jsx": "react",
		"lib": ["ES2022", "DOM"],
