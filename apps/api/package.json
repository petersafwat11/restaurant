{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "dotenv -e ../../.env -- node --watch --require @swc-node/register src/main.ts",
    "generate:i18n-types": "node --require @swc-node/register scripts/generate-i18n-types.ts",
    "build": "nest build",
    "start": "dotenv -e ../../.env -- node dist/main.js",
