{
	"$schema": "https://json.schemastore.org/tsconfig",
	"display": "Next.js",
	"extends": "./base.json",
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"jsx": "preserve",
		"allowJs": true,
		"noEmit": true,
		"plugins": [{ "name": "next" }]
	}
}
