{
	"$schema": "https://json.schemastore.org/tsconfig",
	"display": "React Native (Expo)",
	"extends": "./base.json",
	"compilerOptions": {
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"jsx": "react-native",
		"allowJs": true,
		"noEmit": true,
		"types": ["expo", "node"]
	}
}
